---
import Base from '../../../layouts/Base.astro';
---

<Base
  title="Request received"
  description="We'll reply within two business days."
  path="/contact/thanks/"
>
  <main>
    <section class="section" style="padding-top: var(--space-16);">
      <div class="container container--narrow">
        <h1 class="t-display" style="margin-bottom: var(--space-8);">Request received.</h1>

        <div class="t-body t-muted" style="max-width: 480px;">
          <p style="margin-bottom: var(--space-6);">
            We'll reply within two business days. In the meantime, here's what to read:
          </p>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-4);">
            <li><a href="/methodology/">The TVA methodology →</a></li>
            <li><a href="/stack/">The four-property stack →</a></li>
          </ul>
          <p class="t-muted" style="margin-top: var(--space-8);"> Rome</p>
        </div>
      </div>
    </section>
  </main>
</Base>
