---
import Base from '../layouts/Base.astro';
import SectionLabel from '../components/SectionLabel.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTAButton from '../components/CTAButton.astro';
import TerminalPanel from '../components/TerminalPanel.astro';
---

<Base
  title="Home"
  description="AI for GTM that actually ships. We deploy AI agents, data pipelines, event sites, and competitive intel into your sales, marketing, and CS stack."
  path="/"
>
  <!-- ProfessionalService schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "subagent/gtm",
    "image": "https://subagentgtm.com/og/og-image.png",
    "url": "https://subagentgtm.com",
    "priceRange": "$$$$",
    "description": "AI for GTM engineering firm. Claude Code subagents for sales, marketing, and customer success teams.",
    "areaServed": "United States",
    "serviceType": [
      "AI for GTM",
      "Claude Code for GTM",
      "AI SDR replacement",
      "Pipeline hygiene",
      "RFP response",
      "ICP discovery",
      "Data enrichment",
      "Competitive intelligence"
    ]
  })} />

  <!-- FAQPage schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are you an agency?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. We're a GTM engineering firm. We build and hand off. Retainers are for ongoing engineering and data maintenance — not ads, copy, or managed services."
        }
      },
      {
        "@type": "Question",
        "name": "Do we own what you build?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Every engagement ships to your repo. You own the code, the CLAUDE.md, the subagents, and the data. We don't lock you in."
        }
      },
      {
        "@type": "Question",
        "name": "How is this different from 11x, Artisan, or any other AI SDR tool?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Those are products. We build custom. They train on your value prop; we train on your prospect's problems first. The output passes the Forward Test or it doesn't send."
        }
      },
      {
        "@type": "Question",
        "name": "What if we don't use Claude Code yet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We'll set it up with you. Every engagement starts with a CLAUDE.md we write for your team and ends with a handoff session that trains your operators to modify the subagents we built."
        }
      },
      {
        "@type": "Question",
        "name": "What does this cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Engagements are fixed-fee, scoped in discovery. Data work starts at $2K. Subagent builds typically run $15K–$75K depending on scope. Retainers for ongoing engineering start at $6K/mo. No hourly billing."
        }
      },
      {
        "@type": "Question",
        "name": "How fast can you ship?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most subagent builds ship in 2–4 weeks. Event registration sites in 5–7 business days. Data work in hours, not weeks."
        }
      }
    ]
  })} />

  <!-- Background grid texture -->
  <div class="bg-grid" aria-hidden="true"></div>

  <main>
    <!-- ============================================
         HERO — Above the fold
         ============================================ -->
    <section class="section" style="padding-top: var(--space-16);">
      <div class="container">
        <div class="hero-enter" style="--delay: 0;">
          <span class="t-micro">AI FOR GTM · BUILT ON CLAUDE CODE</span>
        </div>

        <div class="hero-enter" style="--delay: 1;">
          <h1 class="t-display-xl" style="margin: var(--space-6) 0 var(--space-6);">
            AI for GTM that actually ships.
          </h1>
        </div>

        <div class="hero-enter" style="--delay: 2;">
          <p class="t-body t-muted" style="max-width: 640px; margin-bottom: var(--space-12);">
            We deploy AI agents, data pipelines, event sites, and competitive intel into your sales, marketing, and CS stack. You own the build.
          </p>
        </div>

        <!-- Terminal visual with typing animation -->
        <div class="hero-enter" style="--delay: 3;">
          <TerminalPanel pill="STAGED">
            <div class="terminal-lines" id="terminal-output">
              <div class="terminal-line"><span class="terminal__prompt">$</span> claude subagent run pipeline-hygiene --dry-run</div>
              <div class="terminal-line terminal-line--gap"><span class="terminal__slash">/</span> reading 847 open opps from salesforce</div>
              <div class="terminal-line"><span class="terminal__slash">/</span> scoring against forward-test rubric</div>
              <div class="terminal-line"><span class="terminal__slash">/</span> 23 deals flagged: no activity > 21 days</div>
              <div class="terminal-line"><span class="terminal__slash">/</span> 8 deals flagged: no next step logged</div>
              <div class="terminal-line"><span class="terminal__slash">/</span> 4 deals flagged: stage inconsistent with activity</div>
              <div class="terminal-line terminal-line--gap"><span class="terminal__arrow">→</span> drafting 23 re-engagement messages</div>
              <div class="terminal-line"><span class="terminal__arrow">→</span> self-scoring against forward-test</div>
              <div class="terminal-line"><span class="terminal__arrow">→</span> 14 passed (threshold 7/9)</div>
              <div class="terminal-line"><span class="terminal__arrow">→</span> 9 regenerated</div>
              <div class="terminal-line"><span class="terminal__arrow">→</span> 7 passed on second pass</div>
              <div class="terminal-line"><span class="terminal__arrow">→</span> 2 skipped: insufficient signal</div>
              <div class="terminal-line terminal-line--gap"><span class="terminal__check">✓</span> 21 messages staged for review</div>
              <div class="terminal-line"><span class="terminal__check">✓</span> pipeline-hygiene report saved to /reports/2026-04-17.md<span class="terminal__cursor"></span></div>
            </div>
          </TerminalPanel>
        </div>

        <!-- Social proof strip -->
        <div class="hero-enter" style="--delay: 4;">
          <div style="margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-2);">
            <span class="t-micro">OPERATORS FROM · SNAPDOCS · SALESFORCE · MICROSOFT · DATABRICKS (DATAJOY)</span>
            <span class="t-micro">3,000+ AI NEWS DIGEST SUBSCRIBERS · FOUR OPERATING PROPERTIES · SHIPPED</span>
          </div>
        </div>

        <!-- Primary CTA -->
        <div class="hero-enter" style="--delay: 5;">
          <div style="margin-top: var(--space-12);">
            <CTAButton href="/contact/" label="→ Book a build" variant="primary" large={true} caption="Fixed-fee engagements. Deliverable you own. No seat licenses." />
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 1 — What we build
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <SectionLabel number="01" label="THE STACK" />

        <h2 class="t-display" style="margin: var(--space-4) 0 var(--space-6);">
          Four properties. One team.
        </h2>

        <p class="t-body t-muted" style="max-width: 720px; margin-bottom: var(--space-12);">
          Every AI GTM agency promises to build. We already ship. subagent<span class="slash">/</span>gtm is the engineering layer over four operating properties — each one proven, each one in production, each one wired together through Claude Code subagents versioned in your repo.
        </p>

        <div class="grid grid--4 stagger-children">
          <ServiceCard
            label="DATA"
            title="Validate, clean, enrich, discover."
            body="300K+ records a month. 91% owner match accuracy. Delivered in hours, not weeks."
            href="/services/data-subagents/"
          />
          <ServiceCard
            label="HEALTHCARE DATA"
            title="Healthcare provider data, NPI-verified."
            body="2.4M+ provider records. 40+ specialties. No annual contracts."
            href="/services/data-subagents/"
          />
          <ServiceCard
            label="WEB + CONVERSION"
            title="Sub-one-second sites. Real SEO."
            body="700+ pages built. 98 average PageSpeed. 2x industry CTR on paid social."
            href="/services/web-subagents/"
          />
          <ServiceCard
            label="COMPETITIVE INTEL"
            title="Your competitors' hiring playbook."
            body="27,000+ active postings tracked. 11,000+ companies. Weekly refresh."
            href="/services/intel-subagents/"
          />
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 2 — The Forward Test
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <SectionLabel number="02" label="METHODOLOGY" />

        <h2 class="t-display" style="margin: var(--space-4) 0 var(--space-6);">
          Every message passes the Forward Test. Or it doesn't send.
        </h2>

        <div class="t-body t-muted" style="max-width: 720px; margin-bottom: var(--space-12);">
          <p style="margin-bottom: var(--space-6);">
            Most AI SDR tools failed because they optimized for the sender. They scraped a LinkedIn title, plugged in a value prop, and pressed go. The output was slop. Inboxes rejected it. Prospects mocked it. Trust in AI GTM collapsed.
          </p>
          <p>
            We took the opposite approach. We built a single quality standard — the <a href="/methodology/">Forward Test</a> — and trained every subagent to enforce it. The Forward Test asks one question: <em>Would the recipient forward this to their boss, their peer, or their team?</em> If yes, the message sends. If no, the subagent regenerates. No human ever sees a message that wouldn't be forwarded.
          </p>
        </div>

        <!-- Three pillar cards -->
        <div class="grid grid--3 stagger-children">
          <div class="card">
            <span class="card__label">SPECIFIC</span>
            <span class="card__title">Names. Numbers. Dates.</span>
            <span class="card__body">No generic "noticed you're hiring." A specific permit, a specific raise, a specific hire, a specific tech stack change.</span>
          </div>
          <div class="card">
            <span class="card__label">TIMELY</span>
            <span class="card__title">Last 30 days.</span>
            <span class="card__body">If the signal is older, the message doesn't send. Ideally the last 7. Stale signals are discarded before drafting.</span>
          </div>
          <div class="card">
            <span class="card__label">ACTIONABLE</span>
            <span class="card__title">They can act today.</span>
            <span class="card__body">Not next quarter. Something concrete, scoped, and doable this week. The recipient has something to do right now.</span>
          </div>
        </div>

        <div style="margin-top: var(--space-8);">
          <a href="/methodology/" class="btn">Read the full methodology →</a>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 3 — What we build for sales, marketing, CS
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <SectionLabel number="03" label="SUBAGENTS" />

        <h2 class="t-display" style="margin: var(--space-4) 0 var(--space-12);">
          Twelve services. Three GTM functions. One engineering team.
        </h2>

        <div class="grid grid--3 stagger-children">
          <!-- Sales -->
          <div>
            <h3 class="t-h3" style="margin-bottom: var(--space-6);">Sales</h3>
            <ul class="service-list">
              <li><a href="/services/ai-sdr-replacement/">AI SDR replacement</a> <span class="t-muted t-small">(Forward Test-trained agents)</span></li>
              <li><a href="/services/pipeline-hygiene/">Pipeline hygiene & stale-deal resurrection</a></li>
              <li><a href="/services/icp-discovery/">ICP discovery from closed-won data</a></li>
              <li><a href="/services/hubspot-breeze/">HubSpot Breeze</a> / <a href="/services/salesforce-agentforce/">Salesforce Agentforce</a> deployment</li>
            </ul>
          </div>

          <!-- Marketing -->
          <div>
            <h3 class="t-h3" style="margin-bottom: var(--space-6);">Marketing</h3>
            <ul class="service-list">
              <li><a href="/services/event-abm/">Event-driven ABM</a> <span class="t-muted t-small">(SharpPages + Verum + orchestration)</span></li>
              <li><a href="/services/data-subagents/">Data enrichment pipelines</a> <span class="t-muted t-small">(Verum + Provyx)</span></li>
              <li><a href="/services/trust-center/">SOC 2 / HIPAA trust center buildout</a></li>
              <li><a href="/services/intel-subagents/">Competitive intel & battlecards</a> <span class="t-muted t-small">(Fieldwork)</span></li>
            </ul>
          </div>

          <!-- Customer Success -->
          <div>
            <h3 class="t-h3" style="margin-bottom: var(--space-6);">Customer Success</h3>
            <ul class="service-list">
              <li><a href="/services/rfp-response/">RFP & security questionnaire response</a></li>
              <li><a href="/services/pipeline-hygiene/">CRM cleanup as perennial subscription</a></li>
              <li><a href="/services/pe-portco-gtm/">Post-PE GTM rebuild for portfolio companies</a></li>
              <li><a href="/services/team-training/">Team training & handoff</a> <span class="t-muted t-small">(every engagement)</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 4 — Social proof
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <SectionLabel number="04" label="PROOF" />

        <h2 class="t-display" style="margin: var(--space-4) 0 var(--space-12);">
          We don't pitch. We ship.
        </h2>

        <div class="grid grid--4 stagger-children">
          <div class="stat">
            <span class="stat__value">700+</span>
            <span class="stat__label">PAGES BUILT — SHARPPAGES</span>
          </div>
          <div class="stat">
            <span class="stat__value">$20K+</span>
            <span class="stat__label">MRR, 5 CUSTOMERS, 0 AD SPEND — VERUM</span>
          </div>
          <div class="stat">
            <span class="stat__value">27,000+</span>
            <span class="stat__label">ACTIVE POSTINGS TRACKED — FIELDWORK</span>
          </div>
          <div class="stat">
            <span class="stat__value">3,000+</span>
            <span class="stat__label">WEEKLY READERS — AI NEWS DIGEST</span>
          </div>
        </div>

        <blockquote class="t-quote">
          "I've been looking for a healthcare data provider for 3 years, and I finally found one."
          <footer class="t-micro" style="margin-top: var(--space-4); font-style: normal;">— Colin, Division Sales Manager, Medical Devices (Provyx customer)</footer>
        </blockquote>
      </div>
    </section>

    <!-- ============================================
         SECTION 5 — FAQ
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <SectionLabel number="05" label="QUESTIONS" />

        <h2 class="t-display" style="margin: var(--space-4) 0 var(--space-12);">
          The questions everyone asks.
        </h2>

        <div class="faq-list" style="max-width: 720px;">
          <div class="faq-item">
            <h3 class="t-h3">Are you an agency?</h3>
            <p class="t-body t-muted">No. We're a GTM engineering firm. We build and hand off. Retainers are for ongoing engineering and data maintenance — not ads, copy, or managed services.</p>
          </div>

          <div class="faq-item">
            <h3 class="t-h3">Do we own what you build?</h3>
            <p class="t-body t-muted">Yes. Every engagement ships to your repo. You own the code, the CLAUDE.md, the subagents, and the data. We don't lock you in.</p>
          </div>

          <div class="faq-item">
            <h3 class="t-h3">How is this different from 11x, Artisan, or any other AI SDR tool?</h3>
            <p class="t-body t-muted">Those are products. We build custom. They train on your value prop; we train on your prospect's problems first. The output passes the Forward Test or it doesn't send.</p>
          </div>

          <div class="faq-item">
            <h3 class="t-h3">What if we don't use Claude Code yet?</h3>
            <p class="t-body t-muted">We'll set it up with you. Every engagement starts with a CLAUDE.md we write for your team and ends with a handoff session that trains your operators to modify the subagents we built.</p>
          </div>

          <div class="faq-item">
            <h3 class="t-h3">What does this cost?</h3>
            <p class="t-body t-muted">Engagements are fixed-fee, scoped in discovery. Data work starts at $2K. Subagent builds typically run $15K–$75K depending on scope. Retainers for ongoing engineering start at $6K/mo. No hourly billing.</p>
          </div>

          <div class="faq-item">
            <h3 class="t-h3">How fast can you ship?</h3>
            <p class="t-body t-muted">Most subagent builds ship in 2–4 weeks. Event registration sites in 5–7 business days. Data work in hours, not weeks.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         SECTION 6 — Second CTA
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container" style="text-align: center;">
        <h2 class="t-display" style="margin-bottom: var(--space-6);">Ready to ship?</h2>

        <p class="t-body t-muted" style="max-width: 560px; margin: 0 auto var(--space-8);">
          Tell us what you want built. We'll reply within two business days with a fixed quote. If we're not the right fit, we'll say so.
        </p>

        <CTAButton href="/contact/" label="→ Book a build" variant="primary" large={true} />
      </div>
    </section>

    <!-- ============================================
         SECTION 7 — Founder's note
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <SectionLabel number="06" label="FROM ROME" />

        <div class="t-body" style="max-width: 640px; margin-top: var(--space-8);">
          <p style="margin-bottom: var(--space-6);">
            Most AI GTM vendors sell you a seat license, show you a demo, and disappear. We were building on the other side of that for fifteen years.
          </p>
          <p style="margin-bottom: var(--space-6);">
            I was the second salesperson at Snapdocs, ran the Health and Life Sciences territory at Microsoft, closed multi-million-dollar contracts at Salesforce, led sales at Datajoy before Databricks acquired us, and spent seven years at Wells Fargo banking Bay Area tech treasuries. I've sat on every side of the GTM table — buyer, seller, operator, investor-adjacent.
          </p>
          <p style="margin-bottom: var(--space-6);">
            What I kept seeing: companies paying for AI tools they couldn't operate, running playbooks their teams didn't own, and watching AI SDR pilots quietly die six months in.
          </p>
          <p style="margin-bottom: var(--space-6);">
            So we built the opposite. Four operating properties in production, a single methodology (the <a href="/methodology/">Forward Test</a>) that governs everything we ship, and a build-and-hand-off model that leaves your team more capable than when we started.
          </p>
          <p style="margin-bottom: var(--space-8);">
            If you want a seat license, Gartner has a directory. If you want to ship, <a href="/contact/">book a build</a>.
          </p>
          <p class="t-muted">— Rome Thorndike</p>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  /* ========================================================================
     Background grid — faint depth texture matching OG image aesthetic
     ======================================================================== */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--surface-2) 1px, transparent 1px),
      linear-gradient(90deg, var(--surface-2) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.07;
    pointer-events: none;
    z-index: 0;
  }

  main {
    position: relative;
    z-index: 1;
  }

  /* ========================================================================
     Hero entrance — staggered fade-up on page load
     ======================================================================== */
  .hero-enter {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 0.7s var(--ease) forwards;
    animation-delay: calc(var(--delay) * 120ms + 100ms);
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ========================================================================
     Terminal typing — line-by-line progressive reveal
     ======================================================================== */
  .terminal-lines {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
  }

  .terminal-line {
    opacity: 0;
    transform: translateX(-4px);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .terminal-line--gap {
    margin-top: 1.2em;
  }

  :global(.terminal--typing) .terminal-line {
    animation: terminalLineIn 0.25s var(--ease) forwards;
  }

  /* Stagger each line — 14 lines, ~120ms apart = ~1.7s total */
  :global(.terminal--typing) .terminal-line:nth-child(1)  { animation-delay: 0ms; }
  :global(.terminal--typing) .terminal-line:nth-child(2)  { animation-delay: 140ms; }
  :global(.terminal--typing) .terminal-line:nth-child(3)  { animation-delay: 260ms; }
  :global(.terminal--typing) .terminal-line:nth-child(4)  { animation-delay: 360ms; }
  :global(.terminal--typing) .terminal-line:nth-child(5)  { animation-delay: 440ms; }
  :global(.terminal--typing) .terminal-line:nth-child(6)  { animation-delay: 520ms; }
  :global(.terminal--typing) .terminal-line:nth-child(7)  { animation-delay: 680ms; }
  :global(.terminal--typing) .terminal-line:nth-child(8)  { animation-delay: 780ms; }
  :global(.terminal--typing) .terminal-line:nth-child(9)  { animation-delay: 860ms; }
  :global(.terminal--typing) .terminal-line:nth-child(10) { animation-delay: 940ms; }
  :global(.terminal--typing) .terminal-line:nth-child(11) { animation-delay: 1020ms; }
  :global(.terminal--typing) .terminal-line:nth-child(12) { animation-delay: 1100ms; }
  :global(.terminal--typing) .terminal-line:nth-child(13) { animation-delay: 1320ms; }
  :global(.terminal--typing) .terminal-line:nth-child(14) { animation-delay: 1440ms; }

  @keyframes terminalLineIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hide cursor until last line reveals */
  .terminal__cursor {
    opacity: 0;
  }
  :global(.terminal--typing) .terminal-line:last-child .terminal__cursor {
    animation: cursorAppear 0.01s 1600ms forwards;
  }
  @keyframes cursorAppear {
    to { opacity: 1; }
  }

  /* ========================================================================
     Scroll reveal — sections fade up on viewport entry
     ======================================================================== */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children (cards, stats) within a visible section */
  .stagger-children > * {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease);
  }

  .is-visible .stagger-children > *:nth-child(1) { transition-delay: 0ms; opacity: 1; transform: translateY(0); }
  .is-visible .stagger-children > *:nth-child(2) { transition-delay: 80ms; opacity: 1; transform: translateY(0); }
  .is-visible .stagger-children > *:nth-child(3) { transition-delay: 160ms; opacity: 1; transform: translateY(0); }
  .is-visible .stagger-children > *:nth-child(4) { transition-delay: 240ms; opacity: 1; transform: translateY(0); }

  /* ========================================================================
     Enhanced card hover — lift + shadow
     ======================================================================== */
  :global(.card) {
    transition:
      border-color var(--duration-base) var(--ease),
      transform var(--duration-base) var(--ease),
      box-shadow var(--duration-base) var(--ease);
  }

  :global(.card:hover) {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  /* ========================================================================
     Existing styles
     ======================================================================== */
  .service-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .service-list li {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .faq-item h3 {
    margin-bottom: var(--space-3);
  }

  .faq-item p {
    margin: 0;
  }
</style>

<script>
  // Terminal typing — trigger when terminal scrolls into view
  const terminalEl = document.getElementById('terminal-output');
  if (terminalEl) {
    const terminalPanel = terminalEl.closest('.terminal');
    const terminalObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && terminalPanel) {
          terminalPanel.classList.add('terminal--typing');
          terminalObs.disconnect();
        }
      });
    }, { threshold: 0.3 });
    if (terminalPanel) terminalObs.observe(terminalPanel);
  }

  // Scroll reveal — sections fade in on viewport entry
  const revealEls = document.querySelectorAll('.scroll-reveal');
  if (revealEls.length > 0) {
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach((el) => revealObs.observe(el));
  }
</script>
