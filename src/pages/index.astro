---
import Base from '../layouts/Base.astro';
import CTAButton from '../components/CTAButton.astro';
---

<Base
  title="Home"
  description="Your GTM, rebuilt with AI. Pipeline you trust. Outbound that converts. Data in hours. Fixed-fee GTM engineering for revenue teams."
  path="/"
>
  <!-- ProfessionalService schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "subagent/gtm",
    "image": "https://subagentgtm.com/og/og-image.png",
    "url": "https://subagentgtm.com",
    "priceRange": "$$$$",
    "description": "GTM engineering firm. We build AI agents for pipeline, outbound, data, and competitive intel. Fixed-fee. You own everything we build.",
    "areaServed": "United States",
    "serviceType": [
      "AI for GTM",
      "GTM Engineering",
      "Pipeline Hygiene",
      "AI Outbound",
      "Data Enrichment",
      "Competitive Intelligence"
    ]
  })} />

  <!-- FAQPage schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are you an agency?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. We build and hand off. No managed campaigns. No ad buying. No retainers for work we do on your behalf. Your team runs everything."
        }
      },
      {
        "@type": "Question",
        "name": "Do we own what you build?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Everything. The AI agents, the data pipelines, the workflows. If we ended tomorrow, your team keeps running exactly what we built. No lock-in."
        }
      },
      {
        "@type": "Question",
        "name": "What does this cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fixed-fee, scoped in a discovery call. Data work starts at $2K. AI agent builds run $15K–$75K depending on scope. Ongoing engineering starts at $6K/mo. No hourly billing."
        }
      }
    ]
  })} />

  <!-- Background grid -->
  <div class="bg-grid" aria-hidden="true"></div>

  <main>
    <!-- ============================================
         ABOVE THE FOLD (Harry Dry steps 1-5)
         ============================================ -->
    <section class="section" style="padding-top: var(--space-16);">
      <div class="container">
        <div class="hero-enter" style="--delay: 0;">
          <span class="t-micro">GTM ENGINEERING</span>
        </div>

        <div class="hero-enter" style="--delay: 1;">
          <h1 class="t-display-xl" style="margin: var(--space-6) 0 var(--space-6);">
            Your GTM, rebuilt with AI.
          </h1>
        </div>

        <div class="hero-enter" style="--delay: 2;">
          <p class="t-body t-muted" style="max-width: 560px; margin-bottom: var(--space-12);">
            Pipeline you trust. Outbound that converts. Data in hours.
          </p>
        </div>

        <!-- Pipeline digest — visual dashboard -->
        <div class="hero-enter" style="--delay: 3;">
          <div class="digest" id="digest-panel">
            <div class="digest__header">
              <span>PIPELINE DIGEST</span>
              <span class="t-muted">Week of Apr 14</span>
            </div>

            <!-- Big numbers -->
            <div class="digest__stats">
              <div class="digest__stat">
                <span class="digest__stat-value">$340K</span>
                <span class="digest__stat-label">RECOVERED</span>
              </div>
              <div class="digest__stat">
                <span class="digest__stat-value">21</span>
                <span class="digest__stat-label">MESSAGES SENT</span>
              </div>
              <div class="digest__stat">
                <span class="digest__stat-value">3</span>
                <span class="digest__stat-label">DEALS RESURRECTED</span>
              </div>
            </div>

            <!-- Pipeline accuracy bars -->
            <div class="digest__bars">
              <div class="digest__bar-row">
                <span class="digest__bar-label">This week</span>
                <div class="digest__bar-track">
                  <div class="digest__bar-fill digest__bar-fill--current" style="--target-width: 94%;"></div>
                </div>
                <span class="digest__bar-value digest__bar-value--accent">94%</span>
              </div>
              <div class="digest__bar-row">
                <span class="digest__bar-label">Last week</span>
                <div class="digest__bar-track">
                  <div class="digest__bar-fill digest__bar-fill--prev" style="--target-width: 78%;"></div>
                </div>
                <span class="digest__bar-value">78%</span>
              </div>
              <span class="digest__bar-caption">Pipeline accuracy</span>
            </div>
          </div>
        </div>

        <!-- Social proof -->
        <div class="hero-enter" style="--delay: 4;">
          <div style="margin-top: var(--space-8);">
            <span class="t-micro">SNAPDOCS · SALESFORCE · MICROSOFT · DATABRICKS · WELLS FARGO</span>
          </div>
        </div>

        <!-- CTA -->
        <div class="hero-enter" style="--delay: 5;">
          <div style="margin-top: var(--space-12);">
            <CTAButton href="/contact/" label="→ Book a build" variant="primary" large={true} caption="Fixed-fee. No seat licenses. You own everything we build." />
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         WHAT WE FIX (Harry Dry step 6)
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <div class="grid grid--3 stagger-children">
          <a href="/services/pipeline-hygiene/" class="card fix-card">
            <span class="card__label">PIPELINE</span>
            <span class="card__title">Your pipeline is lying.</span>
            <span class="card__body">Weekly truth digest built from CRM activity — not rep self-reporting. Stale deals resurrected into live conversations. Forecast accuracy your board can actually plan around.</span>
            <span class="card__arrow">Learn more →</span>
          </a>

          <a href="/services/ai-sdr-replacement/" class="card fix-card">
            <span class="card__label">OUTBOUND</span>
            <span class="card__title">Your outbound isn't worth reading.</span>
            <span class="card__body">AI agents that research the prospect before they draft. Messages that get replies — and get forwarded. Nothing sends that isn't worth the recipient's time.</span>
            <span class="card__arrow">Learn more →</span>
          </a>

          <a href="/services/data-subagents/" class="card fix-card">
            <span class="card__label">DATA</span>
            <span class="card__title">Your data is wrong. And expensive.</span>
            <span class="card__body">Contacts validated, enriched, and delivered in hours. 80% less than your current vendor. No annual contract. No stale records.</span>
            <span class="card__arrow">Learn more →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         PROOF (Harry Dry steps 7-8)
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container">
        <blockquote class="t-quote">
          "They rebuilt our outbound in three weeks. My team runs it now. Reply rate tripled. No vendor dependency."
          <footer class="t-micro" style="margin-top: var(--space-4); font-style: normal;">— VP Sales, Series B SaaS</footer>
        </blockquote>

        <!-- What you get -->
        <div class="deliverables">
          <div class="deliverable">
            <span class="deliverable__what">Weekly pipeline digest</span>
            <span class="deliverable__why">Know which deals are real before your Monday forecast call.</span>
          </div>
          <div class="deliverable">
            <span class="deliverable__what">Outbound that passes a quality gate</span>
            <span class="deliverable__why">No AI slop leaving your org. Every message researched, scored, and worth reading.</span>
          </div>
          <div class="deliverable">
            <span class="deliverable__what">Clean data on demand</span>
            <span class="deliverable__why">Stop waiting weeks for validated contacts. Stop overpaying for stale databases.</span>
          </div>
          <div class="deliverable">
            <span class="deliverable__what">Competitive hiring intel</span>
            <span class="deliverable__why">Know when competitors are staffing up, paying more, or entering your territory.</span>
          </div>
        </div>

        <p class="t-muted t-small" style="margin-top: var(--space-12);">
          Built by operators from Snapdocs, Salesforce, Microsoft, and Databricks. <a href="/methodology/">See how we work →</a>
        </p>

        <!-- FAQ accordion -->
        <div class="faq-section" style="margin-top: var(--space-16);">
          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="t-h3">Are you an agency?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p class="t-body t-muted">No. We build and hand off. No managed campaigns. No ad buying. No retainers for work we do on your behalf. Your team runs everything.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="t-h3">Do we own what you build?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p class="t-body t-muted">Everything. The AI agents, the data pipelines, the workflows. If we ended tomorrow, your team keeps running exactly what we built. No lock-in.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-toggle" aria-expanded="false">
              <span class="t-h3">What does this cost?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p class="t-body t-muted">Fixed-fee, scoped in a discovery call. Data work starts at $2K. AI agent builds run $15K–$75K depending on scope. Ongoing engineering starts at $6K/mo. No hourly billing.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         CTA + FOUNDER (Harry Dry steps 9-10)
         ============================================ -->
    <section class="section scroll-reveal">
      <div class="container" style="text-align: center;">
        <h2 class="t-display" style="margin-bottom: var(--space-6);">Ready to rebuild your GTM?</h2>

        <p class="t-body t-muted" style="max-width: 480px; margin: 0 auto var(--space-8);">
          Tell us what's broken. Fixed quote in two business days.
        </p>

        <CTAButton href="/contact/" label="→ Book a build" variant="primary" large={true} />
      </div>
    </section>

    <section class="section scroll-reveal">
      <div class="container">
        <div class="t-body t-muted" style="max-width: 560px;">
          <p>
            Fifteen years at Snapdocs, Salesforce, Microsoft, and Databricks. I kept seeing teams buy AI tools nobody could operate. So we built a firm that builds AI for your GTM stack, trains your team to run it, and leaves. — <span style="color: var(--ink);">Rome Thorndike</span>
          </p>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  /* ========================================================================
     Background grid
     ======================================================================== */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--surface-2) 1px, transparent 1px),
      linear-gradient(90deg, var(--surface-2) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.07;
    pointer-events: none;
    z-index: 0;
  }

  main { position: relative; z-index: 1; }

  /* ========================================================================
     Hero entrance
     ======================================================================== */
  .hero-enter {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 0.7s var(--ease) forwards;
    animation-delay: calc(var(--delay) * 120ms + 100ms);
  }

  @keyframes heroFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ========================================================================
     Pipeline digest — visual dashboard
     ======================================================================== */
  .digest {
    background: var(--surface);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    max-width: 560px;
  }

  .digest__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-mono);
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--surface-2);
  }

  /* Big stat numbers */
  .digest__stats {
    display: flex;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--surface-2);
  }

  .digest__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    opacity: 0;
    transform: translateY(12px);
  }

  .digest__stat-value {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 500;
    line-height: 1;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
  }

  .digest__stat-label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-mono);
    text-transform: uppercase;
    color: var(--muted);
  }

  :global(.digest--active) .digest__stat {
    animation: digestStatIn 0.5s var(--ease) forwards;
  }

  :global(.digest--active) .digest__stat:nth-child(1) { animation-delay: 0ms; }
  :global(.digest--active) .digest__stat:nth-child(2) { animation-delay: 150ms; }
  :global(.digest--active) .digest__stat:nth-child(3) { animation-delay: 300ms; }

  @keyframes digestStatIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Progress bars */
  .digest__bars {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .digest__bar-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .digest__bar-label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-mono);
    text-transform: uppercase;
    color: var(--muted);
    min-width: 80px;
    flex-shrink: 0;
  }

  .digest__bar-track {
    flex: 1;
    height: 8px;
    background: var(--surface-2);
    border-radius: 4px;
    overflow: hidden;
  }

  .digest__bar-fill {
    height: 100%;
    border-radius: 4px;
    width: 0;
    transition: width 1s var(--ease);
  }

  .digest__bar-fill--current {
    background: var(--accent);
  }

  .digest__bar-fill--prev {
    background: var(--muted);
    opacity: 0.5;
  }

  :global(.digest--active) .digest__bar-fill {
    width: var(--target-width);
    transition-delay: 500ms;
  }

  :global(.digest--active) .digest__bar-fill--prev {
    transition-delay: 700ms;
  }

  .digest__bar-value {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--muted);
    min-width: 36px;
    text-align: right;
  }

  .digest__bar-value--accent {
    color: var(--accent);
  }

  .digest__bar-caption {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-mono);
    text-transform: uppercase;
    color: var(--muted);
    margin-top: var(--space-2);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .digest__stats {
      gap: var(--space-6);
    }

    .digest__stat-value {
      font-size: var(--fs-h2);
    }

    .digest__bar-label {
      min-width: 60px;
      font-size: 10px;
    }
  }

  /* ========================================================================
     Fix cards
     ======================================================================== */
  .fix-card {
    text-decoration: none;
    color: inherit;
  }

  :global(.card) {
    transition:
      border-color var(--duration-base) var(--ease),
      transform var(--duration-base) var(--ease),
      box-shadow var(--duration-base) var(--ease);
  }

  :global(.card:hover) {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  /* ========================================================================
     Deliverables
     ======================================================================== */
  .deliverables {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: var(--space-12);
  }

  .deliverable {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--surface-2);
  }

  .deliverable:first-child {
    border-top: 1px solid var(--surface-2);
  }

  .deliverable__what {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 500;
    color: var(--ink);
    min-width: 240px;
    flex-shrink: 0;
  }

  .deliverable__why {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--muted);
    line-height: var(--lh-body);
  }

  @media (max-width: 768px) {
    .deliverable {
      flex-direction: column;
      gap: var(--space-2);
    }

    .deliverable__what {
      min-width: auto;
    }
  }

  /* ========================================================================
     FAQ accordion
     ======================================================================== */
  .faq-section {
    display: flex;
    flex-direction: column;
    max-width: 720px;
  }

  .faq-item {
    border-bottom: 1px solid var(--surface-2);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--surface-2);
  }

  .faq-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: var(--space-6) 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--ink);
  }

  .faq-toggle:hover {
    opacity: 0.8;
  }

  .faq-icon {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 300;
    color: var(--muted);
    transition: transform var(--duration-base) var(--ease);
    flex-shrink: 0;
    margin-left: var(--space-4);
  }

  .faq-item.is-open .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--duration-slow) var(--ease);
  }

  .faq-item.is-open .faq-answer {
    max-height: 200px;
  }

  .faq-answer p {
    margin: 0;
    padding-bottom: var(--space-6);
  }

  /* ========================================================================
     Scroll reveal
     ======================================================================== */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stagger-children > * {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease);
  }

  .is-visible .stagger-children > *:nth-child(1) { transition-delay: 0ms; opacity: 1; transform: translateY(0); }
  .is-visible .stagger-children > *:nth-child(2) { transition-delay: 80ms; opacity: 1; transform: translateY(0); }
  .is-visible .stagger-children > *:nth-child(3) { transition-delay: 160ms; opacity: 1; transform: translateY(0); }
</style>

<script>
  // Digest line reveal
  const digestEl = document.getElementById('digest-panel');
  if (digestEl) {
    const digestObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          digestEl.classList.add('digest--active');
          digestObs.disconnect();
        }
      });
    }, { threshold: 0.3 });
    digestObs.observe(digestEl);
  }

  // Scroll reveal
  const revealEls = document.querySelectorAll('.scroll-reveal');
  if (revealEls.length > 0) {
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach((el) => revealObs.observe(el));
  }

  // FAQ accordion
  document.querySelectorAll('.faq-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      if (!item) return;
      const isOpen = item.classList.contains('is-open');
      // Close all
      document.querySelectorAll('.faq-item.is-open').forEach((el) => {
        el.classList.remove('is-open');
        const toggle = el.querySelector('.faq-toggle');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
      });
      // Open clicked (if it was closed)
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
