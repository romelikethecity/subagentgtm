---
import Base from '../../layouts/Base.astro';
import TCOChart from '../../components/TCOChart.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<Base
  title="Pricing"
  description="Build a subagent in 21 days for $25K–$45K. We run it for you going forward at $7.5K–$12K/mo. You own the system from day one. Cancel operate anytime."
  path="/pricing/"
>
  <!-- Service / pricing schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Offer",
    "name": "subagent/gtm, Build a Subagent",
    "description": "Fixed-fee Claude Code subagent build. Shipped in 2–3 weeks. Customer owns the repo.",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "minPrice": 25000,
      "maxPrice": 45000,
      "priceCurrency": "USD"
    },
    "url": "https://subagentgtm.com/pricing/"
  })} />

  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How fast can you ship?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Two to three weeks for a single-subagent build. Four to six weeks for a multi-subagent system. Most agencies and consulting firms quote 90 days to six months for the same scope. We're faster because we deploy proven subagents from a library, configured to your ICP and data, not built first-principles each time."
        }
      },
      {
        "@type": "Question",
        "name": "Do you actually run this for us going forward?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Default mode is we operate the system after the build, daily monitoring, weekly reporting, quarterly tune-ups. Most clients take this because they don't have the engineering bandwidth to run Claude Code subagents in production. The TCO chart assumes you take operate."
        }
      },
      {
        "@type": "Question",
        "name": "What if we'd rather run it ourselves?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Take it. The build is yours at handoff, repo, prompts, rubrics, data pipelines. If your team has the engineering bandwidth, skip operate. The Year-1 cost drops to just the build fee. We'll still train your team during the engagement at no extra cost."
        }
      },
      {
        "@type": "Question",
        "name": "Can we cancel operate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Anytime. No migration cost. The system is already in your repo running on your infrastructure. We just stop pushing changes."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a discovery fee?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Discovery calls are free. We scope, quote, and only proceed if both sides see fit."
        }
      }
    ]
  })} />

  <div class="bg-grid" aria-hidden="true"></div>

  <main>

    <!-- ============================================
         HERO — speed differentiator
         ============================================ -->
    <section class="section pricing-hero">
      <div class="container">
        <span class="t-micro t-accent">PRICING · BUILT, OPERATED, OWNED</span>

        <h1 class="pricing-hero__title">
          We build it in 21 days.<br>
          Run it for you. <em>You own the code.</em>
        </h1>

        <p class="pricing-hero__sub">
          We deploy proven subagents from a library, configured to your ICP and data, so the build ships in two to three weeks, not three months. Then we operate the system going forward at a flat monthly fee, or you take it in-house whenever you're ready. The system is yours from day one.
        </p>

        <div class="pricing-hero__cta">
          <CTAButton variant="primary" href="/contact/" label="→ Fix your GTM" large={true} />
          <span class="pricing-hero__caption">Fixed quote in two business days.</span>
        </div>
      </div>
    </section>

    <!-- ============================================
         TCO CHART — the cost story
         ============================================ -->
    <section class="section section--tight">
      <div class="container">
        <div class="pricing-section-head">
          <span class="t-micro">01 / TOTAL COST OF OWNERSHIP</span>
          <h2 class="t-display pricing-section-title">
            Build it in-house: $540K and 6 months.<br>
            <em>Build it with us, fully operated:</em> $145K and 3 weeks.
          </h2>
          <p class="pricing-hero__sub" style="margin-top: var(--space-4); max-width: 720px;">
            $35K to build, then $10K/mo for us to run it for you for the next eleven months. Cancel operate anytime, your team takes the keys, the chart goes back down to $35K.
          </p>
        </div>

        <TCOChart variant="full" />
      </div>
    </section>

    <!-- ============================================
         MILESTONES — outcome-based timeline
         ============================================ -->
    <section class="section section--tight">
      <div class="container">
        <div class="pricing-section-head">
          <span class="t-micro">02 / WHAT YOU GET, WHEN</span>
          <h2 class="t-display pricing-section-title">
            What's in your hands at <em>each milestone</em>.
          </h2>
        </div>

        <div class="milestones">

          <div class="milestone">
            <div class="milestone__marker">
              <span class="milestone__dot"></span>
              <span class="milestone__when">WEEK 1</span>
            </div>
            <div class="milestone__content">
              <h3 class="milestone__name">Your ICP, refined</h3>
              <p class="milestone__outcome">
                A scored list of trigger sources matched to your closed-won data. The first one hundred candidate signals waiting in your dashboard. The first fifty drafted sequences queued for your approval before anything sends.
              </p>
            </div>
          </div>

          <div class="milestone">
            <div class="milestone__marker">
              <span class="milestone__dot"></span>
              <span class="milestone__when">WEEK 3</span>
            </div>
            <div class="milestone__content">
              <h3 class="milestone__name">First sequence live</h3>
              <p class="milestone__outcome">
                Asset-grade messages sending to triggered prospects. Forward rate metric tracking from message one. Loom library walking your team through every subagent we shipped, what it does, how to modify it.
              </p>
            </div>
          </div>

          <div class="milestone">
            <div class="milestone__marker">
              <span class="milestone__dot"></span>
              <span class="milestone__when">MONTH 3</span>
            </div>
            <div class="milestone__content">
              <h3 class="milestone__name">First quarterly report</h3>
              <p class="milestone__outcome">
                Forward rate vs benchmark, by segment. Triggers that converted, triggers that didn't. A second trigger source added based on the data. Your CRO has a number to put in the board deck.
              </p>
            </div>
          </div>

          <div class="milestone">
            <div class="milestone__marker">
              <span class="milestone__dot"></span>
              <span class="milestone__when">MONTH 6</span>
            </div>
            <div class="milestone__content">
              <h3 class="milestone__name">Per-segment TVA tuning</h3>
              <p class="milestone__outcome">
                Enough send data to tune the TVA rubric per ICP segment. Two campaigns running in parallel where there was one. Your team trained to modify the rubric without our help.
              </p>
            </div>
          </div>

          <div class="milestone">
            <div class="milestone__marker">
              <span class="milestone__dot milestone__dot--final"></span>
              <span class="milestone__when">MONTH 12</span>
            </div>
            <div class="milestone__content">
              <h3 class="milestone__name">Year of forward-rate data</h3>
              <p class="milestone__outcome">
                Eleven months of forward-rate trend data. Take operate in-house, your team takes the keys, the system keeps running. Or keep us operating. The decision is yours, and the system stays yours either way.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================
         PRICING TIERS — 4 cards
         ============================================ -->
    <section class="section section--tight">
      <div class="container">
        <div class="pricing-section-head">
          <span class="t-micro">03 / PRICING</span>
          <h2 class="t-display pricing-section-title">
            Four ways to engage. <em>Customer owns the code.</em>
          </h2>
        </div>

        <div class="tiers">
          <!-- Tier 1: Subagent Build -->
          <div class="tier">
            <div class="tier__head">
              <span class="tier__num">01</span>
              <span class="tier__label">SUBAGENT BUILD</span>
            </div>
            <div class="tier__price">
              <span class="tier__price-val">$25K</span>
              <span class="tier__price-sep">–</span>
              <span class="tier__price-val">$45K</span>
            </div>
            <span class="tier__price-note">Fixed-fee · 2–3 weeks</span>
            <p class="tier__desc">
              One subagent, scoped in discovery. Trigger detection, asset generation, TVA scoring rubric. Shipped to your repo.
            </p>
            <ul class="tier__features">
              <li>Single subagent (e.g. AI SDR replacement)</li>
              <li>Custom trigger source(s)</li>
              <li>TVA rubric tuned to your ICP</li>
              <li>90-minute team handoff</li>
              <li>You own the repo from day one</li>
            </ul>
            <a href="/contact/" class="tier__cta">Fix your GTM →</a>
          </div>

          <!-- Tier 2: System Build -->
          <div class="tier tier--feature">
            <div class="tier__head">
              <span class="tier__num">02</span>
              <span class="tier__label">SYSTEM BUILD</span>
              <span class="tier__pill">MOST CHOSEN</span>
            </div>
            <div class="tier__price">
              <span class="tier__price-val">$55K</span>
              <span class="tier__price-sep">–</span>
              <span class="tier__price-val">$95K</span>
            </div>
            <span class="tier__price-note">Fixed-fee · 4–6 weeks</span>
            <p class="tier__desc">
              Multi-subagent system. AI SDR + Pipeline Hygiene + ICP discovery shipped together, sharing data pipelines.
            </p>
            <ul class="tier__features">
              <li>3–5 subagents working together</li>
              <li>Shared data layer + reporting</li>
              <li>Per-subagent TVA rubric</li>
              <li>Full team training session</li>
              <li>Loom library of how-it-works videos</li>
            </ul>
            <a href="/contact/" class="tier__cta">Fix your GTM →</a>
          </div>

          <!-- Tier 3: Operate -->
          <div class="tier">
            <div class="tier__head">
              <span class="tier__num">03</span>
              <span class="tier__label">OPERATE</span>
              <span class="tier__pill">DEFAULT</span>
            </div>
            <div class="tier__price">
              <span class="tier__price-val">$7.5K</span>
              <span class="tier__price-sep">–</span>
              <span class="tier__price-val">$12K</span>
            </div>
            <span class="tier__price-note">Per month · we run it · cancel anytime</span>
            <p class="tier__desc">
              We run the system you own. Daily monitoring, weekly reporting, quarterly tune-ups. Most clients take this. Take it in-house whenever ready.
            </p>
            <ul class="tier__features">
              <li>Daily monitoring + intervention</li>
              <li>Trigger source maintenance</li>
              <li>Weekly forward-rate reporting</li>
              <li>Quarterly TVA rubric tune-up</li>
              <li>Cancel anytime, no migration cost</li>
            </ul>
            <a href="/contact/" class="tier__cta">Fix your GTM →</a>
          </div>

          <!-- Tier 4: Maintain -->
          <div class="tier">
            <div class="tier__head">
              <span class="tier__num">04</span>
              <span class="tier__label">MAINTAIN</span>
            </div>
            <div class="tier__price">
              <span class="tier__price-val">$4K</span>
            </div>
            <span class="tier__price-note">Per month · light-touch</span>
            <p class="tier__desc">
              Lights-on retainer for teams running their own subagents. Model upgrades, dependency bumps, monthly health check.
            </p>
            <ul class="tier__features">
              <li>Claude/dependency upgrades</li>
              <li>Monthly system health check</li>
              <li>Bug fix queue</li>
              <li>2-hour ad-hoc support / month</li>
              <li>No campaign or content work</li>
            </ul>
            <a href="/contact/" class="tier__cta">Fix your GTM →</a>
          </div>
        </div>

        <p class="tiers__note">
          Data subscriptions (Verum, Provyx, Fieldwork feeds) start at $1K/month and stack with any tier. Discovery calls are free.
        </p>
      </div>
    </section>

    <!-- ============================================
         WHAT YOU GET — three pillars
         ============================================ -->
    <section class="section section--tight">
      <div class="container">
        <div class="pricing-section-head">
          <span class="t-micro">04 / WHAT MAKES THIS DIFFERENT</span>
          <h2 class="t-display pricing-section-title">
            Three things every engagement delivers.
          </h2>
        </div>

        <div class="pillars">
          <div class="pillar">
            <span class="pillar__num">01</span>
            <h3 class="pillar__name">You own the code</h3>
            <p class="pillar__desc">
              Every subagent ships to your repo. CLAUDE.md, prompts, rubrics, data pipelines. If we ended tomorrow, your team continues running exactly what we built.
            </p>
          </div>

          <div class="pillar">
            <span class="pillar__num">02</span>
            <h3 class="pillar__name">TVA-graded outbound</h3>
            <p class="pillar__desc">
              Every message scored against the TVA rubric (Specific · Timely · Actionable). Below 7/9, regenerate. Three failed regenerations, skip the prospect.
            </p>
          </div>

          <div class="pillar">
            <span class="pillar__num">03</span>
            <h3 class="pillar__name">Your team trained</h3>
            <p class="pillar__desc">
              90-minute handoff session per subagent. Loom library. Quarterly check-ins for 12 months. You leave more capable, not more dependent.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         NOT A FIT — disqualifier
         ============================================ -->
    <section class="section section--tight" id="not-a-fit">
      <div class="container">
        <div class="pricing-section-head">
          <span class="t-micro">05 / NOT A FIT</span>
          <h2 class="t-display pricing-section-title">
            We won't take the engagement if <em>any of these are true</em>.
          </h2>
          <p class="t-body t-muted" style="max-width: 640px; margin-top: var(--space-3);">
            Better to call it now than burn each other's time. If any of the below describe you, we'll say no on the discovery call and refund any deposit.
          </p>
        </div>

        <div class="disqualify">
          <div class="disqualify__row">
            <span class="disqualify__mark">✕</span>
            <div class="disqualify__copy">
              <span class="disqualify__title">You want a seat license.</span>
              <span class="disqualify__detail">If you're shopping for a SaaS subscription with a per-seat price, you're shopping in the wrong category. We build custom systems. The output is software, not a login.</span>
            </div>
          </div>

          <div class="disqualify__row">
            <span class="disqualify__mark">✕</span>
            <div class="disqualify__copy">
              <span class="disqualify__title">You're below $3M ARR.</span>
              <span class="disqualify__detail">The build investment doesn't return at smaller scale. You'll get more from a $99/mo Clay seat plus a contractor than from a $35K subagent build. Come back at $3M.</span>
            </div>
          </div>

          <div class="disqualify__row">
            <span class="disqualify__mark">✕</span>
            <div class="disqualify__copy">
              <span class="disqualify__title">You expect us to write campaign copy.</span>
              <span class="disqualify__detail">We engineer the system. Your team owns the message and the brand voice. If you need a copywriter or an ad agency, we'll refer one, but it's not us.</span>
            </div>
          </div>

          <div class="disqualify__row">
            <span class="disqualify__mark">✕</span>
            <div class="disqualify__copy">
              <span class="disqualify__title">You won't give us API access.</span>
              <span class="disqualify__detail">Subagents need real CRM, real signals, and real outbound infrastructure to score against. If your security review on AI access takes more than 30 days, the engagement won't ship inside the build window.</span>
            </div>
          </div>

          <div class="disqualify__row">
            <span class="disqualify__mark">✕</span>
            <div class="disqualify__copy">
              <span class="disqualify__title">You want us to run paid ads.</span>
              <span class="disqualify__detail">We don't manage ad spend. Subagents around your funnel? Yes. Buying media on your behalf? No. SharpPages can build the landing pages; we'll wire the subagents; an agency can buy the media. Three different jobs.</span>
            </div>
          </div>

          <div class="disqualify__row">
            <span class="disqualify__mark">✕</span>
            <div class="disqualify__copy">
              <span class="disqualify__title">You won't ever consider taking it in-house.</span>
              <span class="disqualify__detail">The whole model is built on you eventually owning the system. If you want a forever-managed black box where the vendor holds the keys, we're the wrong fit. Our pitch is the opposite. We build it well enough that one day you don't need us.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         FAQ
         ============================================ -->
    <section class="section section--tight">
      <div class="container">
        <div class="pricing-section-head">
          <span class="t-micro">06 / QUESTIONS</span>
          <h2 class="t-display pricing-section-title">The pricing questions buyers ask.</h2>
        </div>

        <div class="faq">
          <details class="faq__item">
            <summary class="faq__q">How fast can you ship?</summary>
            <div class="faq__a">
              <p>Two to three weeks for a single-subagent build. Four to six weeks for a multi-subagent system. Most agencies and consulting firms quote 90 days to six months for the same scope. We're faster because we deploy proven subagents from a library, configured to your ICP and data, not built first-principles each time.</p>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Do you actually run this for us going forward?</summary>
            <div class="faq__a">
              <p>Yes. Default mode is we operate the system after the build, daily monitoring, weekly reporting, quarterly tune-ups. Most clients take this because they don't have the engineering bandwidth to run Claude Code subagents in production. The TCO chart on this page assumes you take operate.</p>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">What if we'd rather run it ourselves?</summary>
            <div class="faq__a">
              <p>Take it. The build is yours at handoff, repo, prompts, rubrics, data pipelines. If your team has the engineering bandwidth, skip operate. The Year-1 cost drops to just the build fee. We'll still train your team during the engagement at no extra cost.</p>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Can we cancel operate?</summary>
            <div class="faq__a">
              <p>Anytime. No migration cost. The system is already in your repo running on your infrastructure. We just stop pushing changes. No re-implementation, no contract negotiation.</p>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Is there a discovery fee?</summary>
            <div class="faq__a">
              <p>No. Discovery calls are free. We scope, quote in two business days, and only proceed if both sides see fit.</p>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">Do you do hourly?</summary>
            <div class="faq__a">
              <p>No. Builds are fixed-fee. Operate and Maintain are flat monthly. We don't bill for time, we bill for delivered systems.</p>
            </div>
          </details>

          <details class="faq__item">
            <summary class="faq__q">What's included in "data subscriptions"?</summary>
            <div class="faq__a">
              <p>Ongoing feeds from our four operating properties. Verum (300K+ B2B records validated monthly), Provyx (2.4M+ healthcare provider records, NPI-verified), Fieldwork (27,000+ active job postings refreshed weekly). Subscriptions feed your subagents' trigger detection.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- ============================================
         CTA
         ============================================ -->
    <section class="section pricing-cta-section">
      <div class="container">
        <div class="pricing-cta">
          <h2 class="t-display pricing-cta__title">Ready to ship?</h2>
          <p class="pricing-cta__sub">
            Tell us what you want built. Fixed quote in two business days. If we're not the right fit, we'll say so.
          </p>
          <CTAButton variant="primary" href="/contact/" label="→ Fix your GTM" large={true} />
        </div>
      </div>
    </section>

  </main>
</Base>

<style>
  /* ============================================
     Hero
     ============================================ */
  .pricing-hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  .pricing-hero__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(44px, 6.5vw, 72px);
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
    margin: var(--space-6) 0 var(--space-6);
    max-width: 880px;
  }

  .pricing-hero__title em {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .pricing-hero__sub {
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 640px;
    margin: 0 0 var(--space-8);
  }

  .pricing-hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .pricing-hero__caption {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  /* ============================================
     Section heads
     ============================================ */
  .pricing-section-head {
    margin-bottom: var(--space-12);
    max-width: 760px;
  }

  .pricing-section-title {
    margin: var(--space-3) 0 0;
  }

  .pricing-section-title em {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  /* ============================================
     Tier cards (4-up)
     ============================================ */
  .tiers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .tier {
    background: var(--surface);
    border: 1px solid var(--surface-2);
    border-radius: 12px;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }

  .tier:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .tier--feature {
    border-color: var(--accent);
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.06), var(--surface));
  }

  .tier__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .tier__num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--accent);
  }

  .tier__label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .tier__pill {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 3px 8px;
    border: 1px solid var(--accent);
    border-radius: 999px;
  }

  .tier__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .tier__price-val {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 36px;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
  }

  .tier__price-sep {
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 24px;
    line-height: 1;
  }

  .tier__price-note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

